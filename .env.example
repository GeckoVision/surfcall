# surfcall — optional environment (copy to .env; .env is gitignored)

# Live TxODDS session. Normally you don't set these by hand: scripts/subscribe.py
# writes ~/.gecko/txodds-session.json and surfcall auto-reads it. Set these only
# to override that file.
TXODDS_JWT=
TXODDS_API_TOKEN=

# Optional RPC override for scripts/subscribe.py (default: Solana mainnet-beta).
RPC=
